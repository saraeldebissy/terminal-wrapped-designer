{
  "name": "terminal-wrapped-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:web": "pnpm --filter terminal-wrapped-web build",
    "build:cli": "pnpm --filter terminal-wrapped build",
    "dev:web": "pnpm --filter terminal-wrapped-web dev",
    "cli": "node packages/cli/bin/terminal-wrapped",
    "cli:help": "node packages/cli/bin/terminal-wrapped --help"
  },
  "packageManager": "pnpm@10.16.0"
}
